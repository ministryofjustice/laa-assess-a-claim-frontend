{% from "govuk/components/back-link/macro.njk" import govukBackLink %}
{% from "govuk/components/summary-list/macro.njk" import govukSummaryList %}
{% from "govuk/components/tag/macro.njk" import govukTag %}
{% from "components/summaryList.njk" import summaryList %}
{% from "components/linkButton.njk" import linkButton %}

{% extends "base.njk" %}
{% block content %}

  {{ govukBackLink({ text: "Back", href: vm.backLink }) }}

  <div class="govuk-!-margin-bottom-6">
    {{ govukTag({ text: vm.statusText, classes: vm.statusTagClass }) }}
  </div>

  <h1 class="govuk-heading-xl govuk-!-margin-bottom-6">{{ vm.title }}</h1>

  {{ summaryList(vm.summary) }}

  {{ linkButton(vm.assignmentButton, "assignment", "govuk-button--secondary") }}

  {{ govukSummaryList({ classes: "govuk-!-margin-bottom-7", rows: vm.rows }) }}

  <div class="govuk-button-group">
    <a class="govuk-button" href={{vm.assessLink}}>Assess claim</a>
    <a class="govuk-button govuk-button--secondary" href="/">Return to claims</a>
  </div>

{% endblock %}
